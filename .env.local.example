# ─────────────────────────────────────────────
# Copia este archivo como .env.local y completá los valores
# ─────────────────────────────────────────────

# WalletConnect Project ID (obligatorio)
# Obtené uno gratis en: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Nombre de la app (se muestra en el modal de la wallet)
NEXT_PUBLIC_APP_NAME=My Web3 App

# ─── RPC Provider privado (opcional) ────────
# Sin esta key, la app usa RPCs públicos (suficiente para desarrollo).
# Para producción, crear una cuenta en https://app.infura.io y pegar API key.
# RPC privado con mejor velocidad, rate limits y uptime.
# El mismo patrón funciona con Alchemy (https://www.alchemy.com), solo hay que
# cambiar la URL del endpoint en src/config/wagmi.ts.
NEXT_PUBLIC_INFURA_API_KEY=
